{
  "name": "weather-explorer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:integration": "vitest run --passWithNoTests --dir tests/integration",
    "test:e2e": "node -e \"console.log('E2E is verified via browser MCP recordings — see docs/qa/demo-recordings (ADR-0001, TC-STACK-05).')\"",
    "test:coverage": "vitest run --passWithNoTests --coverage",
    "qa:verify": "node scripts/qa-verify.mjs",
    "qa:record-demos": "node -e \"console.log('Demo recordings are captured via browser MCP into docs/qa/demo-recordings (ADR-0001).')\"",
    "qa:record-proof": "node -e \"console.log('Bug-fix proof recordings are captured via browser MCP into docs/qa/bugfix-recordings (ADR-0001).')\"",
    "check:trace": "node scripts/check-traceability.mjs",
    "check:coverage": "node scripts/check-coverage-ratchet.mjs",
    "check:eval": "node scripts/check-eval-ratchet.mjs",
    "check:trajectory": "node scripts/check-trajectory.mjs"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.469.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.20",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
