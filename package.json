{
  "name": "weather-explorer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:integration": "vitest run --passWithNoTests tests/integration",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --passWithNoTests --coverage",
    "qa:verify": "node scripts/qa-verify.mjs",
    "qa:record-demos": "node scripts/record-demos.mjs",
    "check:trace": "node scripts/check-traceability.mjs",
    "check:coverage": "node scripts/check-coverage-ratchet.mjs",
    "check:eval": "node scripts/check-eval-ratchet.mjs",
    "check:trajectory": "node scripts/check-trajectory.mjs",
    "check:recordings": "node scripts/check-recordings.mjs"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.469.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.20",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "axe-core": "^4.12.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "comments": {
    "overrides": "Pin the @emnapi/* peer deps of @napi-rs/wasm-runtime (bundled inside @tailwindcss/oxide-wasm32-wasi) to the version that tarball actually bundles. Without this, npm's ideal tree upgrades the ^1.7.1 peer range to the latest registry release (1.11.1), which is absent from the lock, so `npm ci` fails with EUSAGE on Linux CI. The WASM fallback is never used on the native Linux/Windows binaries."
  },
  "overrides": {
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0"
  }
}
